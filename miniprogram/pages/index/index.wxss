.container {
  padding: 20rpx 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.header-action {
  background: linear-gradient(135deg, #4A90D9, #5AC8FA);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.class-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.class-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.class-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.class-meta {
  font-size: 26rpx;
  color: #999;
}

.action-delete {
  color: #FF3B30;
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  z-index: 101;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.modal-input {
  border: 1rpx solid #E5E5E5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
}

.modal-actions {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.modal-btn.cancel {
  background: #F5F7FA;
  color: #666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #4A90D9, #5AC8FA);
  color: #fff;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

.session-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding-bottom: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.new-session-btn {
  color: #4A90D9;
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border: 1rpx solid #4A90D9;
  border-radius: 24rpx;
}

.all-called-tip {
  color: #34C759;
  font-size: 30rpx;
  font-weight: bold;
  padding-bottom: 40rpx;
}

.roll-stage {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.roll-name {
  font-size: 80rpx;
  font-weight: bold;
  color: #4A90D9;
  text-align: center;
  transition: transform 0.08s;
}

.roll-name.rolling {
  transform: scale(1.1);
  color: #5AC8FA;
}

.roll-controls {
  width: 100%;
  padding-bottom: 60rpx;
}

.start-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #4A90D9, #5AC8FA);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}

.start-btn.disabled {
  opacity: 0.7;
}

.result-panel {
  width: 100%;
  padding-bottom: 60rpx;
  text-align: center;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.result-tip {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 30rpx;
}

.result-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.re-roll {
  color: #4A90D9;
  font-size: 28rpx;
  padding: 20rpx;
}

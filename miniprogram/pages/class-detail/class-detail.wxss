.container {
  padding: 20rpx 30rpx;
}

.class-header {
  background: linear-gradient(135deg, #4A90D9, #5AC8FA);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.class-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.class-count {
  font-size: 28rpx;
  opacity: 0.9;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  background: #fff;
  color: #4A90D9;
  font-size: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.action-btn.primary {
  background: linear-gradient(135deg, #4A90D9, #5AC8FA);
  color: #fff;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.add-link {
  color: #4A90D9;
  font-size: 28rpx;
  font-weight: normal;
}

.student-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.student-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.student-item:last-child {
  border-bottom: none;
}

.student-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.student-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E5E5E5;
}

.student-name {
  font-size: 30rpx;
  color: #333;
}

.delete-btn {
  color: #FF3B30;
  font-size: 26rpx;
  padding: 10rpx 16rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  z-index: 101;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.mode-switch {
  display: flex;
  background: #F5F7FA;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.mode-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
}

.mode-item.active {
  background: #4A90D9;
  color: #fff;
}

.modal-input {
  border: 1rpx solid #E5E5E5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.modal-textarea {
  border: 1rpx solid #E5E5E5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.btn-cancel {
  background: #F5F7FA;
  color: #666;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  text-align: center;
  margin-top: 16rpx;
}

.btn-primary {
  background: #4A90D9;
  color: #000000;
  border-radius: 40rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  margin: 20rpx 0;
  width: 100%;
  display: block;
}

.btn-primary.disabled {
  opacity: 0.5;
}

/* 分享弹窗样式 */
.share-modal {
  max-height: 80vh;
  overflow-y: auto;
}

.share-code-display {
  background: linear-gradient(135deg, #4A90D9, #5AC8FA);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.share-code-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
}

.share-code-text.placeholder {
  font-size: 30rpx;
  font-weight: normal;
  letter-spacing: normal;
}

.share-tips {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  margin-bottom: 30rpx;
}

.share-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.share-action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  background: #F5F7FA;
  color: #333;
  font-size: 28rpx;
}

.share-action-btn.primary {
  background: #4A90D9;
  color: #fff;
}

.share-hint {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

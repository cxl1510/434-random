<view class="container">
  <view class="class-header">
    <view class="class-title">{{classInfo.name}}</view>
    <view class="class-count">{{studentList.length}} 人</view>
    <view wx:if="{{classInfo.shareCode}}" class="share-code-row" bindtap="copyShareCode">
      <text class="share-code-label">分享码：</text>
      <text class="share-code-value">{{classInfo.shareCode}}</text>
      <text class="share-code-tip">点击复制</text>
    </view>
  </view>

  <view class="action-bar">
    <view class="action-btn primary" bindtap="goToRandomCall">开始点名</view>
    <view class="action-btn" bindtap="goToHistory">历史记录</view>
    <view class="action-btn" bindtap="shareClass">分享班级</view>
  </view>

  <view class="section-title">
    <text>学生名单</text>
    <text class="add-link" bindtap="openAddModal">+ 添加学生</text>
  </view>

  <view wx:if="{{loading}}" class="empty-state">加载中...</view>

  <view wx:elif="{{studentList.length === 0}}" class="empty-state">
    <text>暂无学生，点击上方添加</text>
  </view>

  <view wx:else class="student-list">
    <view wx:for="{{studentList}}" wx:key="_id" class="student-item">
      <view class="student-info">
        <image class="student-avatar" src="{{item.avatar || '/images/avatar.png'}}" bindtap="uploadStudentAvatar" data-id="{{item._id}}" data-name="{{item.name}}" />
        <text class="student-name">{{item.name}}</text>
      </view>
      <text class="delete-btn" catchtap="deleteStudent" data-id="{{item._id}}">删除</text>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showAddModal || showShareModal}}" bindtap="closeModals"></view>
  <view class="modal share-modal" wx:if="{{showShareModal}}">
    <view class="modal-title">分享班级</view>
    <view class="share-code-display">
      <text class="share-code-text" wx:if="{{classInfo.shareCode}}">{{classInfo.shareCode}}</text>
      <text class="share-code-text" wx:else>加载中...</text>
    </view>
    <view class="share-tips">
      <text>他人输入此分享码即可加入班级</text>
    </view>
    <view class="share-actions">
      <view class="share-action-btn" bindtap="copyShareCode">复制分享码</view>
      <view class="share-action-btn primary" bindtap="shareToFriend">分享给微信好友</view>
    </view>
    <view class="share-hint">提示：也可点击右上角菜单分享</view>
    <view class="btn-cancel" bindtap="closeModals">关闭</view>
  </view>
  <view class="modal" wx:if="{{showAddModal}}">
    <view class="modal-title">添加学生</view>
    <view class="mode-switch">
      <view class="mode-item {{addMode === 'single' ? 'active' : ''}}" bindtap="switchAddMode" data-mode="single">单个添加</view>
      <view class="mode-item {{addMode === 'batch' ? 'active' : ''}}" bindtap="switchAddMode" data-mode="batch">批量导入</view>
    </view>
    <view wx:if="{{addMode === 'single'}}">
      <input class="modal-input" placeholder="请输入学生姓名" value="{{newStudentName}}" bindinput="onStudentNameInput" />
      <view style="background:#4A90D9;color:#fff;border-radius:40rpx;font-size:32rpx;height:88rpx;line-height:88rpx;text-align:center;margin:20rpx 0;width:100%;" bindtap="addStudent">添加</view>
    </view>
    <view wx:if="{{addMode === 'batch'}}">
      <textarea class="modal-textarea" placeholder="每行一个姓名，如：&#10;张三&#10;李四&#10;王五" value="{{batchNames}}" bindinput="onBatchInput" />
      <view style="background:#4A90D9;color:#fff;border-radius:40rpx;font-size:32rpx;height:88rpx;line-height:88rpx;text-align:center;margin:20rpx 0;width:100%;" bindtap="batchAddStudents">批量添加</view>
    </view>
    <view class="btn-cancel" bindtap="closeAddModal">取消</view>
  </view>
</view>

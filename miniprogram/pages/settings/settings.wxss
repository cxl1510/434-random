.container {
  padding: 20rpx 30rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  padding: 24rpx 30rpx 12rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-label {
  font-size: 32rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCC;
}

.about-info {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.about-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

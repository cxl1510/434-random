.container {
  padding: 20rpx 30rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 班级分组 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.class-group {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.class-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: #4A90D9;
  color: #fff;
}

.class-name {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
}

.class-meta {
  font-size: 24rpx;
  opacity: 0.8;
  margin-right: 12rpx;
}

.class-arrow {
  font-size: 36rpx;
  color: #fff;
  transition: transform 0.3s;
}

.class-arrow.expanded {
  transform: rotate(90deg);
}

/* 班级下的 session 列表 */
.class-group .session-list {
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  gap: 12rpx;
}

.class-group .session-item {
  background: #F9FAFB;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
  overflow: hidden;
}

.class-group .session-header {
  padding: 16rpx 20rpx 12rpx;
}

.class-group .session-title {
  font-size: 28rpx;
}

.class-group .session-meta {
  font-size: 22rpx;
}

.class-group .session-stat-bar {
  padding: 12rpx 20rpx;
  background: #fff;
  border-radius: 0;
}

.class-group .session-records {
  padding: 0 20rpx;
}

.session-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.session-item {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.session-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 16rpx;
}

.session-info-left {
  display: flex;
  flex-direction: column;
}

.session-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.session-meta {
  font-size: 24rpx;
  color: #999;
}

.session-stat-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16rpx 24rpx;
  background: #F9FAFB;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
}

.mini-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mini-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1;
}

.mini-num.green { color: #34C759; }
.mini-num.red { color: #FF3B30; }
.mini-num.orange { color: #FF9500; }

.mini-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.mini-rate {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A90D9;
}

.session-arrow {
  font-size: 32rpx;
  color: #CCC;
  transition: transform 0.3s;
}

.session-arrow.expanded {
  transform: rotate(90deg);
}

.session-records {
  padding: 0 24rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-name {
  font-size: 28rpx;
  color: #333;
}

.record-result {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.record-result.present {
  background: rgba(52, 199, 89, 0.1);
  color: #34C759;
}

.record-result.absent {
  background: rgba(255, 59, 48, 0.1);
  color: #FF3B30;
}

.record-result.leave {
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
}

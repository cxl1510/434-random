<wxs src="../../utils/dateUtil.wxs" module="dateUtil" />
<view class="container">
  <view class="stat-card">
    <view class="stat-row">
      <view class="stat-item">
        <view class="stat-num">{{statistics.total || 0}}</view>
        <view class="stat-label">总点名</view>
      </view>
      <view class="stat-item">
        <view class="stat-num" style="color:#34C759">{{statistics.present || 0}}</view>
        <view class="stat-label">已到</view>
      </view>
      <view class="stat-item">
        <view class="stat-num" style="color:#FF3B30">{{statistics.absent || 0}}</view>
        <view class="stat-label">未到</view>
      </view>
      <view class="stat-item">
        <view class="stat-num" style="color:#FF9500">{{statistics.leave || 0}}</view>
        <view class="stat-label">请假</view>
      </view>
    </view>
    <view class="stat-rate">出勤率：{{statistics.presentRate || 0}}%</view>
  </view>

  <view class="section-title">点名记录</view>

  <view wx:if="{{loading && recordList.length === 0}}" class="empty-state">加载中...</view>

  <view wx:elif="{{recordList.length === 0}}" class="empty-state">
    <text>暂无记录</text>
  </view>

  <view wx:else class="record-list">
    <view wx:for="{{recordList}}" wx:key="_id" class="record-item">
      <view class="record-left">
        <view class="record-name">{{item.studentName}}</view>
        <view class="record-time">{{dateUtil.formatDate(item.callTime)}}</view>
      </view>
      <view class="record-result {{item.result}}">
        <text wx:if="{{item.result === 'present'}}">已到</text>
        <text wx:if="{{item.result === 'absent'}}">未到</text>
        <text wx:if="{{item.result === 'leave'}}">请假</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!hasMore && recordList.length > 0}}" class="no-more">没有更多了</view>
</view>

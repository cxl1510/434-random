/**app.wxss**/
:root {
  --primary: #4A90D9;
  --primary-light: #5AC8FA;
  --bg: #F5F7FA;
  --card-bg: #FFFFFF;
  --text: #333333;
  --text-secondary: #666666;
  --border: #E5E5E5;
  --success: #34C759;
  --warning: #FF9500;
  --danger: #FF3B30;
}

.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 20rpx;
}

button {
  background: initial;
  color: inherit;
  font-size: inherit;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

page {
  background: var(--bg);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  color: var(--text);
}

.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light)) !important;
  color: #fff !important;
  border-radius: 40rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  margin: 20rpx 0;
  width: 100%;
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-primary::after {
  border: none;
}

.btn-danger {
  background: var(--danger);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  margin: 20rpx 0;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}